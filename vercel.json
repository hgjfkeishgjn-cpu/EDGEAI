{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/api-server build && pnpm --filter @workspace/trading-signals build",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs20.x"
      }
    },
    {
      "src": "artifacts/trading-signals/dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/trading-signals/dist/public/$1"
    },
    {
      "src": "/.*",
      "dest": "artifacts/trading-signals/dist/public/index.html"
    }
  ],
  "env": {
    "BETTER_AUTH_API_KEY": "@better_auth_api_key",
    "BETTER_AUTH_SECRET": "@better_auth_secret",
    "DATABASE_URL": "@database_url",
    "ANTHROPIC_API_KEY": "@anthropic_api_key"
  }
}
